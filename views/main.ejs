<!DOCTYPE html>
<html>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js" integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/overall.css" />
  <head>
      <title><%= title %></title>
  </head>
  <body>
      <% if(locals.message){ %>
        <% if(locals.message.success){ %>
          <div class="alert alert-success my-0" role="alert">
            <strong><%= locals.message.success %></strong>
          </div>
        <% } if(locals.message.danger){ %>
          <div class="alert alert-danger my-0" role="alert">
            <strong><%= locals.message.danger %></strong>
          </div>
        <% } if(locals.message.warning){ %>
          <div class="alert alert-warning my-0" role="alert">
            <strong><%= locals.message.warning %></strong>
          </div>
        <% } if(locals.message.info){ %>
          <div class="alert alert-info my-0" role="alert">
            <strong><%= locals.message.info %></strong>
          </div>
        <% } %>
      <% } %>
      <header class="bg-primary p-1 ">
          <div class="container  ">
            <div class="row">
              <div class="col-4">
                <img src="https://sf-nutrition.fr/wp-content/uploads/2023/06/seniorenturnen.png" class="rounded-circle" style="width: 5em;"/>
              </div>
              <div class="hv-100 d-flex justify-content-end align-items-center text-white col-8">
                <% if (user) { %>
                  <a class="nav-link" href="/logout">Déconnexion</a>
                <% } %>
              </div>
            </div>
          </div>
      </header>
      <nav class="navbar navbar-light navbar-expand-lg">
          <div class="container">
            <button class="navbar-toggler p-0 m-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation" style="color: white">
              <span class="navbar-toggler-icon d-flex justify-content-center align-items-center "> <i class="fa-solid fa-bars"></i> </span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
              <div class="navbar-nav">
                <% if (!user) { %>

                  <a class="nav-link <% if (page === '/train') { %> active <% }  %>" aria-current="page" href="/">Accueil</a>
                  <!-- <div class="navbar-nav"> -->
                  <a class="nav-link <% if (page === '/login') { %> active <% }  %>" href="/login">Connexion</a>
                  <a class="nav-link <% if (page === '/signup') { %> active <% }  %>" href="/#payment-form">M'inscrire</a>
                  <!-- </div> -->
                <% } else { %>
                  <a class="nav-link <% if (page === '/academy') { %> active <% }  %>" href="/academy">Académie</a>
                  <a class="nav-link <% if (page === '/train') { %> active <% }  %>" href="/train">Entraînement</a>
                  <a class="nav-link  <% if (page === '/nutrition') { %> active <% }  %>" href="/nutrition/<%= (new Date()).getFullYear()+"-"+((new Date()).getMonth()+1)+"-"+(new Date()).getDate() %>">Nutrition</a>
                  <li class="nav-item dropdown">
                    <a href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" class="dropdown-toggle nav-link <% if (page.startsWith('/profile')) { %> active <% }  %>"> 
                      Profile
                      <%
                        if (locals.profileNotification){
                          %> <span class="badge badge-light">!</span><%
                        }
                    ;%>
                    </a>
                    <ul class="dropdown-menu">
                      <li><a class="dropdown-item" href="/profile/objectif">Aperçu</a></li>
                      <li><a class="dropdown-item" href="/profile/progression">Progression</a></li>
                      <li><a class="dropdown-item" href="/profile/compte">Compte</a></li>
                    </ul>
                  </li>
                <% } %>
              </div>
            </div>
          </div>
        </nav>
        <% if (page.startsWith('/profile')) { %> 
          <nav class="navbar secondary-navbar p-0 navbar-expand-lg">
            <div class="container">
              <div class=" navbar-collapse" id="secondayNavbarNavAltMarkup">
                <div class="navbar-nav">
                    <a class="nav-link" href="/profile/objectif">Aperçu</a>
                    <a class="nav-link" href="/profile/progression">Progression</a>
                    <a class="nav-link" href="/profile/compte">Compte</a>
                </div>
              </div>
            </div>
          </nav>
        <% }  %>
      <main class="w-100 min-vh-100">
          <%- mainNotMarged %>
          <div class="container main-container">
            <%- main %>
          </div>
      </main>
      <div class="bg-light shadow mb-0 mt-auto">
        <div class="container">
          <footer class="py-3 mt-4">
            <ul class="nav justify-content-center border-bottom pb-3 mb-3">
              <li class="nav-item"><a href="/" class="nav-link px-2 text-body-secondary">Accueil</a></li>
              <li class="nav-item"><a href="/cgv" class="nav-link px-2 text-body-secondary">CGV</a></li>
              <li class="nav-item"><a href="/contact" class="nav-link px-2 text-body-secondary">Contact</a></li>
              <li class="nav-item"><a href="/cgv" class="nav-link px-2 text-body-secondary">FAQ</a></li>
              <li class="nav-item"><a href="/bibliography" class="nav-link px-2 text-body-secondary">Bibliographie</a></li>
            </ul>
            <p class="text-center text-body-secondary">
              © 2025 Émile Armengaud
            </p>
          </footer>
        </div>
      </div>
  </body>
<style>
  .navbar-toggler-icon {
    background-image: url("data:image/svg+xml,%3csvg viewBox='0 0 30 30'xmlns='http://www.w3.org/2000/svg'%3e%3cpath stroke='red' stroke-width='2'stroke-linecap='round' stroke-miterlimit='10'd='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
  }
</style></html>
