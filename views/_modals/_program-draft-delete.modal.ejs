<div class="modal" id="deleteProgramDraftModal<%= programDraft.id %>" tabindex="-1">   
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Attention ! </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>
                    Vous êtes sur le point de supprimer le brouillon de programme : <%= programDraft.name %>
                </p>
            </div>
            <div class="modal-footer">
                <a href="/program-draft/<%= programDraft.id %>/delete" class="btn btn-danger">Supprimer</a>
            </div>
        </div>
    </div>
</div>