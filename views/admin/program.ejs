<% title = "Child Template" %>exerciseAlerte
<%- contentFor('mainNotMarged') %>  
<form action="/program-draft/<%= programDraft.id %>/train/<%= trainDraft.id %>/edit" method="POST"  enctype="multipart/form-data">
    <div class="row">
        <div id="imageVisualisation" class="col col-8" style="height: 18em; max-width: 70%; background-image: url(/media/photo/palceholder-elderly-fit.jpg); background-size: cover; background-position : center; background-color: rgb(255, 255, 255);">
        </div>
        <div class="col col-4 py-5">
            <h2>
                <div class="d-flex">
                    <a href="/admin/train" class="m-2 ms-0 btn btn-outline-primary"><i class="fa-solid fa-arrow-left-long"></i></a>  
                    <button class="m-2 btn btn-outline-danger block-btn" data-bs-toggle="modal" data-bs-target="#deletePromalModalprogramid"><i class="fa-solid fa-trash"></i></button>   
                    <input type="text" name="name" class="m-2 form-control w-auto h1" placeholder="nom du programme" required/>
                </div>
            </h2>
            <div class="d-flex ">
                <input type="submit" name="save" class="m-2 ms-0 btn btn-primary" value="Sauvegarder"/>
            </div>
        </div>
    </div> 
<%- contentFor('main') %>
    <div class="my-5">
        <input type="file" name="imageUrl" class="form-control my-5" placeholder="Image d'arrière plan" required/>
        <textarea name="description" class="form-control my-5" placeholder="Descripton" required></textarea>
    </div>
    <div class="bg-light py-3 pt-0">
        <table class="table table-striped my-5">
            <thead class="table-dark">
                <tr>
                    <th colspan="3 ">
                    <h3>
                        Séances d'entraînement <input type="submit" name="save" class="btn btn-primary" value="+"/>
                    </h3> 
                    </th>
                </tr>
            </thead>
        </table>
        <div class="card-group  row-cols-2 row-cols-md-3 row-cols-lg-4  g-3">
            <% programDraft.TrainDrafts.forEach(async(train) => { %>
                <div class="col" >
                    <div class="card <% if (train.id === trainDraft.id ) { %> border border-dark bg-light border-opacity-50 <% } %>" style="width: 15em;">
                        <div style="background-image: url(/media/photo/<%= train.imageUrl %>); background-size: cover;" class="card-img-top">
                            <div class="w-100 h-auto p-2 bg-light bg-opacity-75">
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">
                                <button class="btn btn-outline-danger block-btn" data-bs-toggle="modal" data-bs-target="#deleteTrainModal<%= train.id %> "><i class="fa-solid fa-trash"></i></button>   
                                <% if(!train.name) { %>
                                    <% if (train.id === trainDraft.id) { %>
                                        <input type='numer' name='trainName' class='form-control w-auto' placeholder='Entrez un nom de séance'/>
                                    <% } else { %>
                                        <a href="/program-draft/<%= programDraft.id %>/train/<%= train.id %>/edit" >
                                            <i>Nouvelle entrainement</i>
                                        </a> 
                                    <% } %> 
                                <% } else { %> 
                                    <a href="/program-draft/<%= programDraft.id %>/train/<%= train.id %>/edit" class="link link-dark">
                                        <%= train.name %>
                                    </a>
                                <% } %> 
                            </h5>
                            <p class="card-text overflow-auto " style="max-height: 100px;">
                                <% train.ExerciseTrainDrafts.forEach(exercisesTrain => { %>
                                    <%= exercisesTrain.reps %> x <%= exercisesTrain.sets %> : <%= exercisesTrain.Exercise.name %><br>
                                <% }) %>
                            </p>
                            <div class="d-flex justify-content-between">
                                <a href="/program-draft/<%= programDraft.id %>/train-draft/<%= train.id %>/put-prevent" class="btn btn-outline-secondary"><i class="fa-solid fa-angle-left"></i></a>
                                <a href="/program-draft/<%= programDraft.id %>/train-draft/<%= train.id %>/put-next" class="btn btn-outline-secondary"><i class="fa-solid fa-angle-right"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal" id="deleteTrainModal<%= train.id %>" tabindex="-1">  
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Attention ! </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <p>
                                    Vous êtes sur le point de supprimer l'entrainement :<br> <%= train.name || 'entraînement sans nom' %>
                                </p>
                            </div>
                            <div class="modal-footer">
                                <a href="/program-draft/<%= programDraft.id %>/train/<%= train.id %>/delete" class="btn btn-danger">Confirmer</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</form>


    <table class="table table-striped my-5">
        <thead class="table-dark">
            <tr>
                <th colspan="6">
                <h3>
                        Exercices de l'entrainement <%= trainDraft.name %>
                        <button class="btn block-btn btn-primary w-auto" data-bs-toggle="modal" data-bs-target="#addExerciseModal"> + </button> 
                    </h3> 
                </th>
            </tr>
            <tr>
                <th scope="col">
                    Image
                </th>  
                <th scope="col">
                    Nom
                </th>
                <th scope="col">
                    Répétitions
                </th>
                <th scope="col">
                    Type de répétition
                </th>
                <th scope="col">
                    Séries
                </th>
                <th scope="col">
                    Action
                </th>  
            </tr>
        </thead>
        <tbody>
            <% trainDraft.ExerciseTrainDrafts.forEach(exerciseTrainDraft => { %>
                <tr>
                    <td>
                        <img src="/media/photo/<%= exerciseTrainDraft.Exercise.imageUrlPng %>.png" style="width: 4rem;" class="png-gif-img"/>
                    </td>  
                    <td>
                        <%= exerciseTrainDraft.Exercise.name %>
                    </td>
                    <td>
                        <%= exerciseTrainDraft.reps %>
                    </td>
                    <td>
                        <%= exerciseTrainDraft.repsMode %>
                    </td>
                    <td>
                        <%= exerciseTrainDraft.sets %>
                    </td>
                    <td>
                        <button class="btn btn-outline-danger block-btn" data-bs-toggle="modal" data-bs-target="#deleteExerciseModalexercise<%= exerciseTrainDraft.id %>"> <i class="fa-solid fa-trash"></i> </button>
                    </td>  
                </tr>

                <div class="modal" id="deleteExerciseModalexercise<%= exerciseTrainDraft.id %>" tabindex="-1">   
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Attention ! </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <p>
                                    Vous êtes sur le point de supprimer l'exercice :<br> <%= exerciseTrainDraft.Exercise?.name || 'temp null' %>
                                </p>
                            </div>
                            <div class="modal-footer">
                                <a href="/program-draft/<%= programDraft.id %>/train/<%= trainDraft.id %>/exercise/<%= exerciseTrainDraft.id %>/delete" class="btn btn-outline-danger"><i class="fa-solid fa-trash"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            <%}) %>
        </tbody>

        <div class="modal" id="addExerciseModal" tabindex="-1">
            <form action="/program-draft/<%= programDraft.id %>/train/<%= trainDraft.id %>/exercise" method="POST">    
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Ajouter un exercice</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <!-- <select class="form-control my-3" name="exerciseId" placeholder="exercice" >
                                <% exercises.forEach(exercise => {%>
                                    <option ><%= exercise.name %></option>
                                <% }) %>
                            </select> -->
                            <div class="row overflow-auto" style="max-height: 20em; ">
                                <% exercises.forEach(exercise => {%>
                                    <div class="col my-5 p-0">
                                        <div style="background-image: url(/public/media/photo/<%= exercise.imageUrlPng %>);">
                                            <img src="/media/photo/<%= exercise.imageUrlPng %>" class="png-gif-img"  style="width: 8em;"/>
                                            <p>
                                                <input value="<%= exercise.id %>" type="radio" class="" name="exerciseId"/> <%= exercise.name %>
                                            </p>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                            <input type="number" name="reps" class="form-control my-3" placeholder="Répétitions"/>
                            <select class="form-control my-3" name="repsMode" placeholder="mode de répétition" >
                                <option value="scd">Seconde</option>
                                <option value="reps">Répétition</option>

                            </select>
                            <input type="number" name="sets" class="form-control my-3" placeholder="Séries"/>
                        </div>  
                        <div class="modal-footer">
                            <input type="reset" class="btn btn-outline-danger" data-bs-dismiss="modal">
                            <input type="submit" class="btn btn-primary">
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </table>
<%- include('../_modals/_program-draft-delete.modal.ejs', { programDraft : programDraft}); %>

<script src="/js/block.btn.js" type="text/javascript"></script>
<script src="/js/train/previewImage.js" type="text/javascript"></script>
<script src="/js/exercise/image.js" type="text/javascript"></script>

