<% title = "Connexion" %>

<%- contentFor('mainNotMarged') %>
<%- contentFor('main') %>
<h2 class="my-5">Login</h2>

<form action="/login" method="post">
    <p>
      <label for="email" class="text-responsive">Email address</label>
      <input type="email" name="email" class="form-control text-responsive" id="email" aria-describedby="emailHelp" placeholder="Enter email">
    </p>
    <p>
      <label for="password" class="text-responsive">Password</label>
      <input type="password" name="password" class="form-control text-responsive" id="password" placeholder="Password">
    </p>
    <p class="form-check">
      <input type="checkbox" class="form-check-input" id="exampleCheck1">
      <label class="form-check-label  text-responsive" for="exampleCheck1">Check me out</label>
    </p>
    <button type="submit" class="btn btn-primary text-responsive">Submit</button>
  </form>
  <% if (error) { %> 
    
    <div class="alert alert-danger my-3 text-responsive" role="alert">
      <%= message %>
    </div>
    
  <% } %>